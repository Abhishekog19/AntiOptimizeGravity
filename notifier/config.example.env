# Antigravity Quota Tracker — Notifier Configuration
#
# Copy this file to .env in the same directory and edit values.
# All values are optional; the defaults shown below are used if not set.
#
# Usage:  cp config.example.env .env

# CDP port that Antigravity IDE is launched with.
# Must match the --remote-debugging-port flag.
CDP_PORT=9222

# How often to poll for trigger conditions (seconds).
# Lower = faster detection, higher = less CPU. Range: 1–10.
POLL_INTERVAL_SECONDS=2

# Minimum time between captures for the same account (seconds).
# Prevents double-captures when a trigger lingers.
DEBOUNCE_SECONDS=30

# URL of the local dashboard server.
DASHBOARD_URL=http://localhost:4300

# Optional API key for the dashboard (leave blank for local/dev use).
# Must match DASHBOARD_API_KEY in dashboard/.env
DASHBOARD_API_KEY=

# Log verbosity: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO
